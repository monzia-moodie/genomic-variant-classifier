```
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environment — never commit this
.venv/
venv/
env/

# Secrets — NEVER commit these
.env
*.key
*.token

# Large genomic data files
genomic_variant_classifier/data/raw/
genomic_variant_classifier/data/processed/
genomic_variant_classifier/data/images/
*.parquet
*.vcf
*.vcf.gz
*.svs
*.tsv.gz
*.bam
*.bai

# Model weights (large binaries)
genomic_variant_classifier/models/*.pt
genomic_variant_classifier/models/*.pkl

# Jupyter checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# VS Code — keep workspace file, ignore personal settings
.vscode/settings.json
.vscode/launch.json
!genomic-variant-classifier.code-workspace

# Logs
*.log
genomic_variant_classifier/logs/