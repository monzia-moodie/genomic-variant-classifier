notebooks/genomic_variant_classifier/

# Model weights (large binaries)
genomic_variant_classifier/models/*.pt
genomic_variant_classifier/models/*.pkl

# Jupyter checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

